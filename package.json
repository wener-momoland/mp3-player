{
  "name": "minimal-mp3-player",
  "version": "1.1.0",
  "description": "极简本地媒体播放器 - 支持 MP3/MP4 播放和热更新",
  "main": "index.html",
  "scripts": {
    "serve": "npx http-server -p 8080 -c-1",
    "build:android": "npx cap copy android && npx cap sync android",
    "open:android": "npx cap open android"
  },
  "keywords": [
    "mp3",
    "player",
    "music",
    "android",
    "capacitor"
  ],
  "author": "DuMate",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "http-server": "^14.1.1"
  }
}
